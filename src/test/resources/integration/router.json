{
  "apiVersion": "iip.gateway/v1alpha1",
  "kind": "Router",
  "uid": "test-flow-router-uid",
  "workspaceId": "test",
  "id": "test-flow-router",
  "name": "test-flow-router",
  "version": "v1",
  "description": "test flow router",
  "metadata": { "name": "test-flow-router" },
  "spec": {
    "rule": {
      "protocol": "HTTP",
      "match": { "path": "/test/**", "methods": "POST" }
    },
    "destinations": [
      { "destinationRef": { "kind": "Flow", "uid": "test-flow-uid", "id": "test-flow", "name": "test-flow" }, "weight": 100 }
    ]
  }
}
