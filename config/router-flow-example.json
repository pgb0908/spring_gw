{
  "apiVersion": "iip.gateway/v1alpha1",
  "kind": "Router",
  "uid": "flow-router-uid",
  "workspaceId": "dev",
  "id": "flow-router",
  "name": "flow-router",
  "version": "v1",
  "description": "flow router",
  "metadata": { "name": "flow-router" },
  "spec": {
    "rule": {
      "protocol": "HTTP",
      "match": {
        "path": "/api/flow/**",
        "methods": "POST"
      }
    },
    "destinations": [
      {
        "destinationRef": {
          "kind": "Flow",
          "uid": "example-flow-uid",
          "id": "example-flow",
          "name": "example-flow"
        }
      }
    ]
  }
}
