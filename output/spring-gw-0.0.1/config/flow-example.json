{
  "apiVersion": "iip.gateway/v1alpha1",
  "kind": "Flow",
  "metadata": { "name": "example-flow" },
  "spec": {
    "protocol": "HTTP",
    "loadBalancing": {
      "algorithm": "ROUND_ROBIN",
      "targets": [
        {
          "host": "localhost",
          "port": 9001,
          "flow-id": "example-flow",
          "core-id": "core-1"
        }
      ]
    }
  }
}
