{
  "apiVersion": "iip.gateway/v1alpha1",
  "kind": "Listener",
  "metadata": { "name": "main-listener" },
  "spec": {
    "protocol": "HTTP",
    "role": "INGRESS",
    "port": 8080,
    "host": "0.0.0.0",
    "connection": {
      "readTimeout": "10s",
      "writeTimeout": "10s",
      "maxConnections": 5000
    }
  }
}
