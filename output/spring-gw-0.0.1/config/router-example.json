{
  "apiVersion": "iip.gateway/v1alpha1",
  "kind": "Router",
  "uid": "example-router-uid",
  "workspaceId": "dev",
  "id": "example-router",
  "name": "example-router",
  "version": "v1",
  "description": "example router",
  "metadata": { "name": "example-router" },
  "spec": {
    "rule": {
      "protocol": "HTTP",
      "match": {
        "path": "/api/example/**",
        "methods": "GET"
      }
    },
    "destinations": [
      {
        "destinationRef": {
          "kind": "Connector",
          "uid": "example-connector-uid",
          "id": "example-connector",
          "name": "example-connector"
        }
      }
    ]
  }
}
